# Server
HDULIB_MEMORY_HOST=127.0.0.1
HDULIB_MEMORY_PORT=8018
HDULIB_PUBLIC_BASE_URL=http://127.0.0.1:8018

# Storage
HDULIB_STORAGE_DIR=storage
HDULIB_SIGNING_SECRET=replace-with-a-long-random-secret

# Optional OpenAI-compatible AI review endpoint.
# Leave HDULIB_AI_API_KEY empty to use the local fallback review.
# Put real provider URLs, model names, and keys only in .env or server env vars.
HDULIB_AI_BASE_URL=https://api.openai.com/v1
HDULIB_AI_MODEL=gpt-4o-mini
HDULIB_AI_API_KEY=

# Library import options
HDULIB_DETAIL_LIMIT=300
HDULIB_INCLUDE_NO_SEAT=1
